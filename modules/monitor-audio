#!/bin/bash

BASE="${ALFREDO_BASE:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
source "$BASE/lib/ui"

title "🔊 Monitor de Audio en Tiempo Real"

echo -e "${BLUE}🎵 Monitoreando audio activo...${NC}"
echo -e "${YELLOW}Presiona Ctrl+C para detener${NC}"
separator

# Función para mostrar estado del audio
monitor_audio() {
    local previous=""
    while true; do
        clear
        title "🔊 Monitor de Audio"
        
        # Mostrar fecha y hora
        echo -e "${BLUE}🕒 $(date '+%Y-%m-%d %H:%M:%S')${RESET}"
        echo
        
        # Dispositivos activos
        echo "🎯 Dispositivos de audio:"
        pactl list short sinks | while read line; do
            NAME=$(echo "$line" | awk '{print $2}')
            if echo "$line" | grep -q "RUNNING"; then
                echo -e "  ${GREEN}✅ $NAME (ACTIVO)${NC}"
            else
                echo -e "  ${YELLOW}⏸️  $NAME (inactivo)${NC}"
            fi
        done
        echo
        
        # Aplicaciones reproduciendo audio
        echo "🎵 Aplicaciones con audio:"
        APPS=$(pactl list short sink-inputs 2>/dev/null)
        if [ -n "$APPS" ]; then
            echo "$APPS" | while read line; do
                if echo "$line" | grep -q "RUNNING"; then
                    APP=$(pactl list sink-inputs 2>/dev/null | grep -A 10 "Sink Input" | grep "application.process.binary" | head -1 | awk -F'"' '{print $2}')
                    if [ -n "$APP" ]; then
                        echo -e "  ${GREEN}▶️  $APP (reproduciendo)${NC}"
                    else
                        echo -e "  ${GREEN}▶️  Aplicación desconocida${NC}"
                    fi
                fi
            done
        else
            echo -e "  ${YELLOW}⏸️  No hay audio reproduciéndose${NC}"
        fi
        echo
        
        # Volumen
        echo "🔊 Volumen:"
        pactl list sinks | grep -A 10 "State: RUNNING" | grep "Volume:" | head -1 | sed 's/^/  /'
        echo
        
        echo -e "${YELLOW}⏱️  Actualizando cada 2 segundos... (Ctrl+C para salir)${NC}"
        sleep 2
    done
}

monitor_audio
