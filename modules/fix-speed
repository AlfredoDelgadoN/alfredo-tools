#!/bin/bash

BASE="${ALFREDO_BASE:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
source "$BASE/lib/ui"

title "рџ”§ ReparaciГіn de Speed Test"

echo -e "${BLUE}рџ”Ќ Diagnosticando speedtest-cli...${RESET}"
separator

# 1. Verificar conectividad
echo "1пёЏвѓЈ Verificando conectividad a Internet..."
if ping -c 3 8.8.8.8 >/dev/null 2>&1; then
    echo -e "  ${GREEN}вњ… Conectividad OK${NC}"
else
    echo -e "  ${RED}вќЊ Sin conexiГіn a Internet${NC}"
    echo "  рџ’Ў Verifica tu conexiГіn de red"
    exit 1
fi

# 2. Verificar DNS
echo
echo "2пёЏвѓЈ Verificando DNS..."
if ping -c 3 google.com >/dev/null 2>&1; then
    echo -e "  ${GREEN}вњ… DNS OK${NC}"
else
    echo -e "  ${YELLOW}вљ пёЏ  Problemas con DNS${NC}"
    echo "  рџ’Ў Usando DNS alternativo..."
    echo "nameserver 8.8.8.8" | sudo tee /etc/resolv.conf
fi

# 3. Verificar instalaciГіn de speedtest-cli
echo
echo "3пёЏвѓЈ Verificando speedtest-cli..."
if command -v speedtest-cli &>/dev/null; then
    echo -e "  ${GREEN}вњ… Instalado: $(speedtest-cli --version 2>/dev/null | head -1)${NC}"
else
    echo -e "  ${YELLOW}вљ пёЏ  No instalado${NC}"
    echo "  рџ“¦ Instalando..."
    sudo apt install -y speedtest-cli
fi

# 4. Probar speedtest-cli
echo
echo "4пёЏвѓЈ Probando speedtest-cli..."
echo "  рџ”„ Conectando a servidores..."
if speedtest-cli --simple >/dev/null 2>&1; then
    echo -e "  ${GREEN}вњ… Funciona correctamente${NC}"
else
    echo -e "  ${YELLOW}вљ пёЏ  No responde, reinstalando...${NC}"
    
    # Reinstalar con pip
    echo "  рџ“¦ Instalando con pip..."
    pip3 install --upgrade speedtest-cli --user 2>/dev/null || sudo pip3 install speedtest-cli
    
    # Verificar instalaciГіn
    if command -v speedtest-cli &>/dev/null; then
        echo -e "  ${GREEN}вњ… Instalado con pip${NC}"
    else
        echo -e "  ${RED}вќЊ Error en la instalaciГіn${NC}"
        echo "  рџ’Ў InstalaciГіn alternativa:"
        echo "     sudo apt install speedtest-cli"
    fi
fi

# 5. Probar con alfredo
echo
echo "5пёЏвѓЈ Probando alfredo speed..."
if alfredo speed 2>/dev/null; then
    echo -e "  ${GREEN}вњ… Alfredo speed funciona${NC}"
else
    echo -e "  ${YELLOW}вљ пёЏ  Prueba manual: speedtest-cli --simple${NC}"
fi

# 6. Resumen
echo
echo -e "${BLUE}рџ’Ў RECOMENDACIONES${RESET}"
separator

echo "  рџ“Њ Si speedtest-cli no funciona:"
echo "     вЂў Verifica que el puerto 8080 estГ© abierto"
echo "     вЂў Prueba: speedtest-cli --source [tu-IP]"
echo "     вЂў Usa: speedtest-cli --server [servidor-ID]"
echo
echo "  рџ”§ Si el mГіdulo speed falla:"
echo "     вЂў Ejecuta: alfredo fix-speed"
echo "     вЂў Reinstala: sudo apt install --reinstall speedtest-cli"

ok "DiagnГіstico de speed completado"
