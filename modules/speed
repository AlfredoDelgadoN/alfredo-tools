#!/bin/bash

BASE="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

source "$BASE/lib/ui"

title "Alfredo Tools - Speed"


TMPFILE=$(mktemp)

INICIO=$(date +%s)

speedtest --format=json > "$TMPFILE" 2>/dev/null &
PID=$!

SPIN='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
i=0

while kill -0 $PID 2>/dev/null; do
    TIEMPO=$(( $(date +%s) - INICIO ))
    printf "\rRealizando prueba... %s  %2d s" "${SPIN:i:1}" "$TIEMPO"
    i=$(( (i + 1) % ${#SPIN} ))
    sleep 0.1
done

wait $PID

echo

JSON=$(cat "$TMPFILE")
rm -f "$TMPFILE"

if [ $? -ne 0 ] || [ -z "$JSON" ]; then
    fail "No fue posible realizar la prueba."
    exit 1
fi

ISP=$(echo "$JSON" | jq -r '.isp')
SERVER=$(echo "$JSON" | jq -r '.server.name')
LOCATION=$(echo "$JSON" | jq -r '.server.location')

LOCAL_IP=$(echo "$JSON" | jq -r '.interface.internalIp')
PUBLIC_IP=$(echo "$JSON" | jq -r '.interface.externalIp')
VPN=$(echo "$JSON" | jq -r '.interface.isVpn')

PING=$(echo "$JSON" | jq -r '.ping.latency' | awk '{printf "%.2f",$1}')
JITTER=$(echo "$JSON" | jq -r '.ping.jitter' | awk '{printf "%.2f",$1}')

DOWNLOAD=$(echo "$JSON" | jq '.download.bandwidth*8/1000000' | awk '{printf "%.2f",$1}')
UPLOAD=$(echo "$JSON" | jq '.upload.bandwidth*8/1000000' | awk '{printf "%.2f",$1}')

LOSS=$(echo "$JSON" | jq -r '.packetLoss')

field "Proveedor" "$ISP"
field "Servidor" "$SERVER ($LOCATION)"
field "IP pública" "$PUBLIC_IP"
field "Duración" "${TIEMPO} s"

echo

field "Ping" "$PING ms"
field "Jitter" "$JITTER ms"
field "Download" "$DOWNLOAD Mbps"
field "Upload" "$UPLOAD Mbps"
field "Pérdida" "$LOSS %"

echo

if (( $(echo "$DOWNLOAD >= 300" | bc -l) )); then
    ok "Conexión excelente"
elif (( $(echo "$DOWNLOAD >= 100" | bc -l) )); then
    ok "Conexión muy buena"
elif (( $(echo "$DOWNLOAD >= 50" | bc -l) )); then
    ok "Conexión buena"
else
    warn "Conexión lenta"
fi
