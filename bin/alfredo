#!/bin/bash

VERSION="0.1.0"

case "$1" in

    salud)
        bash modules/salud.sh
        ;;
    wifi)
        modules/wifi
        ;;
    discos)
        modules/discos
        ;;
    --version|-v)
        echo "Alfredo Tools $VERSION"
        ;;

    --help|-h|"")
        echo
        echo "========================================="
        echo "        Alfredo Tools $VERSION"
        echo "========================================="
        echo
        echo "Uso:"
        echo
        echo "  alfredo {salud|wifi|discos}"
        echo
        echo "Opciones:"
        echo
        echo "  --help"
        echo "  --version"
        echo
        ;;
esac
