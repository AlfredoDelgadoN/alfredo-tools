#!/bin/bash

BASE_DIR="$(cd "$(dirname "$0")/.." && pwd)"

case "$1" in

    salud)
        "$BASE_DIR/modules/salud"
        ;;
    wifi)
        "$BASE_DIR/modules/wifi"
        ;;
    red)
        "$BASE_DIR/modules/red"
        ;;
   *)
        echo "========================================="
        echo "        Alfredo Tools v0.3"
        echo "========================================="
        echo "Uso:"
        echo "  ./bin/alfredo salud"
        echo "  ./bin/alfredo wifi"
        echo "  ./bin/alfredo red"
        ;;
esac
