#!/bin/bash

if [ -L "$0" ]; then
    SCRIPT_PATH="$(readlink -f "$0")"
else
    SCRIPT_PATH="$0"
fi

BIN_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
BASE="$(cd "$BIN_DIR/.." && pwd)"
export ALFREDO_BASE="$BASE"

show_help() {
    echo "========================================="
    echo "          Alfredo Tools v0.6"
    echo "========================================="
    echo
    echo "Uso:"
    echo "  alfredo salud          - Estado del sistema"
    echo "  alfredo wifi           - Info WiFi"
    echo "  alfredo red            - Info de red"
    echo "  alfredo speed          - Velocidad de Internet"
    echo "  alfredo diagnostico    - Diagnóstico completo 🔍"
    echo "  alfredo reparar        - Reparación automática 🔧"
    echo "  alfredo fix-screen     - Solución rápida pantalla negra 🖥️"
    echo "  alfredo setup-monitors - Configurar monitores 🖥️"
    echo "  alfredo fix-amd        - Solución específica AMD 🟣"
    echo "  alfredo help           - Esta ayuda"
    echo "  alfredo version        - Versión"
    echo
}

check_module() {
    local module="$1"
    local module_path="$BASE/modules/$module"
    
    if [ ! -f "$module_path" ]; then
        echo "❌ Error: Módulo '$module' no encontrado"
        echo "   Buscando en: $module_path"
        exit 1
    fi
    
    if [ ! -x "$module_path" ]; then
        echo "⚠️  El módulo '$module' no es ejecutable"
        echo "   Ejecuta: chmod +x $module_path"
        exit 1
    fi
}

case "$1" in
    salud|wifi|red|speed|diagnostico|reparar|fix-screen|setup-monitors|fix-amd)
        check_module "$1"
        exec "$BASE/modules/$1"
        ;;
    help|--help|-h)
        show_help
        ;;
    version|--version|-v)
        echo "Alfredo Tools v0.6"
        ;;
    *)
        show_help
        exit 1
        ;;
esac
