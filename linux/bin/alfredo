# ============================================================
# MENÚ PRINCIPAL
# ============================================================
show_main_menu() {
    while true; do
        print_header
        print_menu_header "📋 MENÚ PRINCIPAL"
        echo "  Selecciona una categoría:"
        echo ""
        print_option "1" "🔍 Diagnóstico"
        print_option "2" "💻 Sistema"
        print_option "3" "🔧 Reparación"
        print_option "4" "🌐 Red y Conectividad"
        print_option "5" "🌡️  Temperatura"
        print_option "6" "🔊 Audio"
        print_option "7" "🖥️  Pantallas y Gráficos"
        print_option "8" "🚀 Optimización"
        print_option "9" "🖨️  Impresoras"
        print_option "10" "📊 Otros"
        echo ""
        print_exit_option
        echo ""
        read -p "Opción: " MAIN_OPTION
        
        case $MAIN_OPTION in
            1) submenu_diagnostico ;;
            2) submenu_sistema ;;
            3) submenu_reparacion ;;
            4) submenu_red ;;
            5) submenu_temperatura ;;
            6) submenu_audio ;;
            7) submenu_pantallas ;;
            8) submenu_optimizacion ;;
            9) submenu_impresoras ;;
            10) submenu_otros ;;
            0) 
                echo -e "\n${GREEN}👋 ¡Hasta luego!${RESET}"
                exit 0
                ;;
            *) 
                echo -e "${RED}❌ Opción inválida${RESET}" 
                pause 
                ;;
        esac
    done
}

# ============================================================
# EJECUCIÓN DIRECTA (compatibilidad con comandos)
# ============================================================
if [ $# -gt 0 ] && [ "$1" != "help" ] && [ "$1" != "--help" ] && [ "$1" != "-h" ]; then
    # Ejecución directa de módulo
    if [ -f "$BASE/modules/$1" ]; then
        exec "$BASE/modules/$1"
    else
        echo -e "${RED}❌ Error:${RESET} Módulo '${BOLD}$1${RESET}' no encontrado"
        echo -e "${CYAN}💡${RESET} Ejecuta ${BOLD}alfredo${RESET} para ver el menú interactivo"
        exit 1
    fi
else
    # Modo interactivo
    show_main_menu
fi
