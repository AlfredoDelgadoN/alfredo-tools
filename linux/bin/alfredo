        print_option "8" "fix-screen        - Solución de pantalla negra"
        print_option "9" "screen-fix-quick  - Solución rápida de pantalla negra"
        print_option "10" "fix-speed        - Reparación de speed test"
        print_option "11" "fix-screen-duplicates - Reparar procesos duplicados"
        print_option "12" "fix-screen-lxqt  - Reparar pantalla LXQt"
        print_back_option
        echo ""
        read -p "Opción: " OPTION
        
        case $OPTION in
            1) run_module "reparar" ;;
            2) run_module "reparar-todo" ;;
            3) run_module "fix-amd" ;;
            4) run_module "fix-audio" ;;
            5) run_module "fix-pipewire" ;;
            6) run_module "fix-pulse" ;;
            7) run_module "fix-hdmi" ;;
            8) run_module "fix-screen" ;;
