#!/bin/bash

# ============================================================
# CONFIGURACIÓN DE COLORES
# ============================================================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[0;37m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ============================================================
# DETECTAR RUTA BASE
# ============================================================
if [ -L "$0" ]; then
    SCRIPT_PATH="$(readlink -f "$0")"
else
    SCRIPT_PATH="$0"
fi

BIN_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
BASE="$(cd "$BIN_DIR/.." && pwd)"
export ALFREDO_BASE="$BASE"

# ============================================================
# FUNCIONES DE PRESENTACIÓN
# ============================================================
print_header() {
    clear
    echo -e "${CYAN}${BOLD}╔═══════════════════════════════════════════════════════════════════════╗${RESET}"
    echo -e "${CYAN}${BOLD}║    ALFREDO TOOLS v2.0  /  Suite de Diagnóstico y Mantenimiento        ║${RESET}"
    echo -e "${CYAN}${BOLD}╚═══════════════════════════════════════════════════════════════════════╝${RESET}"
    echo ""
}

print_menu_header() {
    echo -e "${YELLOW}${BOLD}═══════════════════════════════════════════════════════════════════════${RESET}"
    echo -e "${BOLD}  $1${RESET}"
    echo -e "${YELLOW}${BOLD}═══════════════════════════════════════════════════════════════════════${RESET}"
    echo ""
}

print_option() {
    printf "  ${GREEN}%2s${RESET}) %s\n" "$1" "$2"
}

print_back_option() {
    echo ""
    printf "  ${YELLOW}%2s${RESET}) %s\n" "0" "Regresar al menú principal"
}

print_exit_option() {
    echo ""
    printf "  ${RED}%2s${RESET}) %s\n" "0" "Salir"
    echo ""
}

pause() {
    echo ""
    read -p "Presiona Enter para continuar..."
}

# ============================================================
# EJECUTAR MÓDULO
# ============================================================
run_module() {
    local module="$1"
    local module_path="$BASE/modules/$module"
    
    if [ ! -f "$module_path" ]; then
        echo -e "${RED}❌ Error:${RESET} Módulo '$module' no encontrado"
        pause
        return 1
    fi
    
    if [ ! -x "$module_path" ]; then
        echo -e "${YELLOW}⚠️  El módulo '$module' no es ejecutable${RESET}"
        pause
        return 1
    fi
    
    clear
    exec "$module_path"
}

# ============================================================
# SUBMENÚES
# ============================================================

submenu_diagnostico() {
    while true; do
        print_header
        print_menu_header "🔍 DIAGNÓSTICO"
        echo "  Selecciona una opción:"
        echo ""
        print_option "1" "diagnostico       - Diagnóstico completo del sistema"
        print_option "2" "diagnostico-memoria - Diagnóstico de memoria RAM"
        print_option "3" "analizar-logs     - Análisis de logs del sistema"
        print_option "4" "estado-actual     - Estado del sistema en tiempo real"
        print_option "5" "verificar-todo    - Verificación completa del sistema"
        print_back_option
        echo ""
        read -p "Opción: " OPTION
        
        case $OPTION in
            1) run_module "diagnostico" ;;
            2) run_module "diagnostico-memoria" ;;
            3) run_module "analizar-logs" ;;
            4) run_module "estado-actual" ;;
            5) run_module "verificar-todo" ;;
            0) return ;;
            *) echo -e "${RED}❌ Opción inválida${RESET}" ; pause ;;
        esac
    done
}

