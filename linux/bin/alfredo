#!/bin/bash

# ============================================================
# CONFIGURACIÓN DE COLORES
# ============================================================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[0;37m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

# ============================================================
# FUNCIONES DE PRESENTACIÓN
# ============================================================
print_header() {
    clear
    echo -e "${CYAN}${BOLD}╔════════════════════════════════════════════════════════════╗${RESET}"
    echo -e "${CYAN}${BOLD}║                    ALFREDO TOOLS v1.0                      ║${RESET}"
    echo -e "${CYAN}${BOLD}║              Suite de Diagnóstico y Mantenimiento          ║${RESET}"
    echo -e "${CYAN}${BOLD}╚════════════════════════════════════════════════════════════╝${RESET}"
    echo ""
}

print_category() {
    echo -e "${YELLOW}${BOLD}█▓▒░ $1 ░▒▓█${RESET}"
    echo -e "${DIM}──────────────────────────────────────────────────────────────────${RESET}"
}

print_module() {
    local name="$1"
    local desc="$2"
    printf "  ${GREEN}▶${RESET} ${BOLD}%-20s${RESET} ${DIM}%s${RESET}\n" "$name" "$desc"
}

print_footer() {
    echo ""
    echo -e "${DIM}──────────────────────────────────────────────────────────────────${RESET}"
    echo -e "${CYAN}💡 Uso:${RESET} ${BOLD}alfredo <módulo>${RESET}  ${DIM}Ejemplo:${RESET} ${BOLD}alfredo salud${RESET}"
    echo -e "${CYAN}📖 Ayuda:${RESET} ${BOLD}alfredo help${RESET}  ${DIM}o${RESET} ${BOLD}alfredo --help${RESET}"
    echo ""
}

# ============================================================
# DETECTAR RUTA BASE
# ============================================================
if [ -L "$0" ]; then
    SCRIPT_PATH="$(readlink -f "$0")"
else
    SCRIPT_PATH="$0"
fi

BIN_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
BASE="$(cd "$BIN_DIR/.." && pwd)"
export ALFREDO_BASE="$BASE"

# ============================================================
# MENÚ PRINCIPAL
# ============================================================
show_menu() {
    print_header
    
    # ============================================================
    # CATEGORÍA: DIAGNÓSTICO
    # ============================================================
    print_category "🔍 DIAGNÓSTICO"
    print_module "diagnostico" "Diagnóstico completo del sistema"
    print_module "diagnostico-memoria" "Diagnóstico de memoria RAM"
    print_module "analizar-logs" "Análisis de logs del sistema"
    print_module "estado-actual" "Estado del sistema en tiempo real"
    print_module "verificar-todo" "Verificación completa del sistema"
    echo ""
    
    # ============================================================
    # CATEGORÍA: SISTEMA
    # ============================================================
    print_category "💻 SISTEMA"
    print_module "salud" "Estado completo del sistema"
    print_module "info" "Resumen rápido del sistema"
    print_module "procesador" "Información del procesador"
    print_module "memoria" "Información de la memoria RAM"
    print_module "discos" "Información de discos y almacenamiento"
    print_module "nvme-status" "Estado del disco NVMe"
    print_module "tiempo-arranque" "Tiempo de arranque del sistema"
    print_module "ultimo-arranque" "Información del último arranque"
    echo ""
    
    # ============================================================
    # CATEGORÍA: REPARACIÓN
    # ============================================================
    print_category "🔧 REPARACIÓN"
    print_module "reparar" "Reparación automática de problemas"
    print_module "reparar-todo" "Reparación completa del sistema"
    print_module "fix-amd" "Solución específica para AMD"
    print_module "fix-audio" "Solución de problemas de audio"
    print_module "fix-pipewire" "Reparación completa de PipeWire"
    print_module "fix-pulse" "Reparación de conexión PulseAudio"
    print_module "fix-hdmi" "Solución de problemas HDMI"
    print_module "fix-screen" "Solución de pantalla negra"
    print_module "screen-fix-quick" "Solución rápida de pantalla negra"
    print_module "fix-speed" "Reparación de speed test"
    echo ""
    
    # ============================================================
    # CATEGORÍA: RED Y CONECTIVIDAD
    # ============================================================
    print_category "🌐 RED Y CONECTIVIDAD"
    print_module "red" "Información de configuración de red"
    print_module "wifi" "Información de conexión WiFi"
    print_module "speed" "Prueba de velocidad de Internet"
    echo ""
    
    # ============================================================
    # CATEGORÍA: TEMPERATURA
    # ============================================================
    print_category "🌡️  TEMPERATURA"
    print_module "temp-cpu" "Monitoreo de temperatura de CPU"
    print_module "temp-discos" "Monitoreo de temperatura de discos"
    print_module "temp-discos-simple" "Temperatura de discos (versión simple)"
    echo ""
    
    # ============================================================
    # CATEGORÍA: AUDIO
    # ============================================================
    print_category "🔊 AUDIO"
    print_module "check-audio" "Verificación rápida de audio"
    print_module "configurar-audio" "Configuración de audio"
    print_module "monitor-audio" "Monitoreo de audio en tiempo real"
    print_module "test-audio" "Prueba de audio"
    echo ""
    
    # ============================================================
    # CATEGORÍA: PANTALLAS Y GRÁFICOS
    # ============================================================
    print_category "🖥️  PANTALLAS Y GRÁFICOS"
    print_module "setup-monitors" "Configuración de monitores"
    print_module "monitor-screen" "Monitoreo de cambios en pantallas"
    print_module "pantalla-negra" "Soluciones para pantalla negra"
    echo ""
    
    # ============================================================
    # CATEGORÍA: OPTIMIZACIÓN
    # ============================================================
    print_category "🚀 OPTIMIZACIÓN"
    print_module "optimizar-arranque" "Optimización del tiempo de arranque"
    print_module "optimizar-memoria" "Optimización de memoria"
    print_module "optimizar-soldada" "Optimización para memoria soldada"
    echo ""
    
    # ============================================================
    # CATEGORÍA: OTROS
    # ============================================================
    print_category "📊 OTROS"
    print_module "historial" "Historial de reparaciones"
    print_module "resumen-ejecutivo" "Resumen ejecutivo del sistema"
    print_module "mac-info" "Información de MacBook"
    echo ""
    
    print_footer
}

# ============================================================
# VERIFICAR Y EJECUTAR MÓDULO
# ============================================================
check_module() {
    local module="$1"
    local module_path="$BASE/modules/$module"
    
    if [ ! -f "$module_path" ]; then
        echo -e "${RED}❌ Error:${RESET} Módulo '${BOLD}$module${RESET}' no encontrado"
        echo -e "${CYAN}💡${RESET} Ejecuta ${BOLD}alfredo${RESET} para ver los módulos disponibles"
        exit 1
    fi
    
    if [ ! -x "$module_path" ]; then
        echo -e "${YELLOW}⚠️  El módulo '${BOLD}$module${RESET}' no es ejecutable"
        echo -e "${CYAN}💡${RESET} Ejecuta: ${BOLD}chmod +x $module_path${RESET}"
        exit 1
    fi
    
    exec "$module_path"
}

# ============================================================
# CASOS PRINCIPALES
# ============================================================
if [ $# -eq 0 ] || [ "$1" = "help" ] || [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
    show_menu
    exit 0
fi

# Verificar si el módulo existe
if [ -f "$BASE/modules/$1" ]; then
    check_module "$1"
else
    echo -e "${RED}❌ Error:${RESET} Módulo '${BOLD}$1${RESET}' no encontrado"
    echo -e "${CYAN}💡${RESET} Ejecuta ${BOLD}alfredo${RESET} para ver los módulos disponibles"
    exit 1
fi
