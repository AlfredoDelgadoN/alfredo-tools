    while true; do
        print_header
        print_menu_header "💻 SISTEMA"
        echo "  Selecciona una opción:"
        echo ""
        print_option "1" "salud             - Estado completo del sistema"
        print_option "2" "info              - Resumen rápido del sistema"
        print_option "3" "procesador        - Información del procesador"
        print_option "4" "memoria           - Información de la memoria RAM"
        print_option "5" "discos            - Información de discos"
        print_option "6" "smart-diagnostico - Diagnóstico SMART de discos"
        print_option "7" "nvme-status       - Estado del disco NVMe"
        print_option "8" "tiempo-arranque   - Tiempo de arranque del sistema"
        print_option "9" "ultimo-arranque   - Información del último arranque"
        print_back_option
        echo ""
        read -p "Opción: " OPTION
        
        case $OPTION in
            1) run_module "salud" ;;
            2) run_module "info" ;;
            3) run_module "procesador" ;;
            4) run_module "memoria" ;;
            5) run_module "discos" ;;
            6) run_module "smart-diagnostico" ;;
            7) run_module "nvme-status" ;;
            8) run_module "tiempo-arranque" ;;
            9) run_module "ultimo-arranque" ;;
            0) return ;;
