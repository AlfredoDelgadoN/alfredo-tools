#!/bin/bash

BASE="${ALFREDO_BASE:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
source "$BASE/lib/ui"

# ============================================
# VARIABLES GLOBALES
# ============================================
AUDIO_ERRORS=0
AUDIO_WARNINGS=0
AUDIO_OK=0
REPAIR_AVAILABLE=false
NEEDS_REPAIR=false

# ============================================
# FUNCIONES AUXILIARES
# ============================================
increment_error() { ((AUDIO_ERRORS++)); NEEDS_REPAIR=true; }
increment_warning() { ((AUDIO_WARNINGS++)); }
increment_ok() { ((AUDIO_OK++)); }

print_status() {
    local status="$1"
    local message="$2"
    case "$status" in
        ok)   echo -e "  ${GREEN}✅ $message${NC}"; increment_ok ;;
        warn) echo -e "  ${YELLOW}⚠️  $message${NC}"; increment_warning ;;
        err)  echo -e "  ${RED}❌ $message${NC}"; increment_error ;;
        info) echo -e "  ${BLUE}ℹ️  $message${NC}" ;;
    esac
}

print_separator() { echo -e "  ${DIM}────────────────────────────────────────${NC}"; }

ask_yes_no() {
    local prompt="$1"
    local default="${2:-n}"
    local yn
    
    if [[ "$default" == "y" ]]; then
        echo -en "  ${CYAN}$prompt [Y/n]: ${NC}"
    else
        echo -en "  ${CYAN}$prompt [y/N]: ${NC}"
    fi
    
    read -r yn
    yn="${yn:-$default}"
    
    [[ "$yn" =~ ^[Yy]$ ]]
}

show_summary() {
    echo
    separator
    echo -e "  ${BOLD}📊 RESUMEN DEL DIAGNÓSTICO${NC}"
    print_separator
    echo -e "  ${GREEN}✅ Correctos:    $AUDIO_OK${NC}"
    echo -e "  ${YELLOW}⚠️  Advertencias: $AUDIO_WARNINGS${NC}"
    echo -e "  ${RED}❌ Errores:      $AUDIO_ERRORS${NC}"
    print_separator
    
    if [[ $NEEDS_REPAIR == true ]]; then
        echo -e "  ${YELLOW}🔧 Se recomienda ejecutar la reparación${NC}"
    elif [[ $AUDIO_ERRORS -eq 0 && $AUDIO_WARNINGS -eq 0 ]]; then
        echo -e "  ${GREEN}🎉 Todo funciona correctamente${NC}"
    else
        echo -e "  ${YELLOW}💡 El sistema funciona con advertencias menores${NC}"
    fi
    separator
    echo
}

# ============================================
#       LINUX - MÓDULO DE AUDIO
# ============================================

# --- Variables específicas de Linux ---
LINUX_AUDIO_SERVER=""
LINUX_DEFAULT_SINK=""
LINUX_DEFAULT_SOURCE=""
LINUX_SINKS=()
LINUX_SOURCES=()
LINUX_HARDWARE=()

linux_detect_audio_server() {
    echo -e "\n${BOLD}📡 Detectando servidor de audio...${NC}"
    print_separator
    
    if pgrep -x "pipewire" &>/dev/null; then
        LINUX_AUDIO_SERVER="pipewire"
        print_status ok "PipeWire detectado (PID: $(pgrep -x pipewire | head -1))"
        
        # Verificar pipewire-pulse
        if pgrep -x "pipewire-pulse" &>/dev/null; then
            print_status ok "PipeWire-Pulse (compatibilidad PulseAudio) activo"
        else
            print_status warn "PipeWire-Pulse no está ejecutándose"
        fi
        
        # Verificar wireplumber
        if pgrep -x "wireplumber" &>/dev/null; then
            print_status ok "WirePlumber (gestor de sesión) activo"
        else
            print_status warn "WirePlumber no está ejecutándose"
        fi
        
    elif pgrep -x "pulseaudio" &>/dev/null; then
        LINUX_AUDIO_SERVER="pulseaudio"
        print_status ok "PulseAudio detectado (PID: $(pgrep -x pulseaudio | head -1))"
        
    else
        LINUX_AUDIO_SERVER="alsa"
        print_status warn "No se detectó PipeWire ni PulseAudio"
        print_status info "Usando ALSA directamente (soporte limitado)"
    fi
    
    # Verificar servicio systemd si aplica
    if command -v systemctl &>/dev/null; then
        echo
        case "$LINUX_AUDIO_SERVER" in
            pipewire)
                if systemctl --user is-active pipewire.service &>/dev/null; then
                    print_status ok "Servicio systemd pipewire.service activo"
                else
                    print_status warn "Servicio systemd pipewire.service inactivo"
                fi
                ;;
            pulseaudio)
                if systemctl --user is-active pulseaudio.service &>/dev/null; then
                    print_status ok "Servicio systemd pulseaudio.service activo"
                else
                    print_status warn "Servicio systemd pulseaudio.service inactivo"
                fi
                ;;
        esac
    fi
}

linux_detect_hardware() {
    echo -e "\n${BOLD}🖥️  Detectando hardware de audio...${NC}"
    print_separator
    
    local found_hw=false
    
    # Detectar tarjetas PCI
    if command -v lspci &>/dev/null; then
        while IFS= read -r line; do
            if [[ -n "$line" ]]; then
                print_status ok "PCI: $line"
                LINUX_HARDWARE+=("$line")
                found_hw=true
            fi
        done < <(lspci 2>/dev/null | grep -i audio)
    fi
    
    # Detectar dispositivos USB
    if command -v lsusb &>/dev/null; then
        while IFS= read -r line; do
            if [[ -n "$line" ]]; then
                print_status ok "USB: $line"
                LINUX_HARDWARE+=("$line")
                found_hw=true
            fi
        done < <(lsusb 2>/dev/null | grep -iE "audio|sound|headset|speaker|microphone")
    fi
    
    # Verificar archivos de dispositivo ALSA
    if [[ -d /dev/snd ]]; then
        local card_count=$(ls -d /dev/snd/card* 2>/dev/null | wc -l)
        if [[ $card_count -gt 0 ]]; then
            print_status ok "Dispositivos ALSA detectados: $card_count tarjeta(s)"
            for card in /dev/snd/card*; do
                local card_name=$(cat "$card/id" 2>/dev/null || echo "desconocido")
                print_status info "  └─ $(basename $card): $card_name"
            done
            found_hw=true
        fi
    else
        print_status err "No existe /dev/snd - posible problema de kernel o permisos"
    fi
    
    if [[ $found_hw == false ]]; then
        print_status err "No se detectó hardware de audio"
    fi
}

linux_check_permissions() {
    echo -e "\n${BOLD}🔐 Verificando permisos...${NC}"
    print_separator
    
    # Verificar grupo audio
    if groups | grep -q audio; then
        print_status ok "Usuario en el grupo 'audio'"
    else
        print_status warn "Usuario NO está en el grupo 'audio'"
        print_status info "Puede causar problemas de permisos"
    fi
    
    # Verificar acceso a dispositivos
    if [[ -r /dev/snd ]]; then
        print_status ok "Acceso de lectura a /dev/snd"
    else
        print_status err "Sin acceso de lectura a /dev/snd"
    fi
    
    if [[ -w /dev/snd ]]; then
        print_status ok "Acceso de escritura a /dev/snd"
    else
        print_status err "Sin acceso de escritura a /dev/snd"
    fi
    
    # Verificar sesión DBus (necesario para PipeWire/PulseAudio)
    if [[ -n "$DBUS_SESSION_BUS_ADDRESS" ]]; then
        print_status ok "Sesión DBus configurada"
    else
        print_status warn "Sesión DBus no configurada"
    fi
    
    # Verificar XDG_RUNTIME_DIR
    if [[ -n "$XDG_RUNTIME_DIR" && -d "$XDG_RUNTIME_DIR" ]]; then
        print_status ok "XDG_RUNTIME_DIR válido: $XDG_RUNTIME_DIR"
    else
        print_status warn "XDG_RUNTIME_DIR no válido o ausente"
    fi
}

linux_check_sinks() {
    echo -e "\n${BOLD}🔊 Dispositivos de salida (Sinks)...${NC}"
    print_separator
    
    if [[ "$LINUX_AUDIO_SERVER" == "alsa" ]]; then
        # Usar aplay para listar con ALSA puro
        if command -v aplay &>/dev/null; then
            aplay -l 2>/dev/null | grep "^card" | while read -r line; do
                print_status info "ALSA: $line"
            done
        fi
        return
    fi
    
    local sinks
    sinks=$(pactl list short sinks 2>/dev/null)
    
    if [[ -z "$sinks" ]]; then
        print_status err "No se encontraron dispositivos de salida"
        return
    fi
    
    local sink_count=0
    local active_count=0
    
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        
        local sink_id=$(echo "$line" | awk '{print $1}')
        local sink_name=$(echo "$line" | awk '{print $2}')
        local sink_state=$(pactl list sinks 2>/dev/null | grep -A 20 "Sink #$sink_id" | grep "State:" | awk '{print $2}')
        local sink_desc=$(pactl list sinks 2>/dev/null | grep -A 20 "Sink #$sink_id" | grep "Description:" | sed 's/.*: //')
        local sink_vol=$(pactl list sinks 2>/dev/null | grep -A 20 "Sink #$sink_id" | grep "Volume:" | head -1 | awk '{print $5}' | sed 's/%//')
        local sink_mute=$(pactl list sinks 2>/dev/null | grep -A 20 "Sink #$sink_id" | grep "Mute:" | awk '{print $2}')
        
        LINUX_SINKS+=("$sink_name")
        ((sink_count++))
        
        echo
        print_status info "Sink #$sink_id: $sink_desc"
        print_status info "  └─ Nombre: $sink_name"
        print_status info "  └─ Estado: $sink_state"
        print_status info "  └─ Volumen: ${sink_vol}%"
        
        if [[ "$sink_mute" == "yes" ]]; then
            print_status warn "  └─ 🔇 MUTADO"
        else
            print_status ok "  └─ 🔊 No silenciado"
        fi
        
        if [[ "$sink_state" == "RUNNING" ]]; then
            ((active_count++))
        fi
    done <<< "$sinks"
    
    echo
    print_status info "Total: $sink_count dispositivo(s), $active_count activo(s)"
    
    # Detectar sink por defecto
    LINUX_DEFAULT_SINK=$(pactl info 2>/dev/null | grep "Default Sink:" | awk '{print $3}')
    if [[ -n "$LINUX_DEFAULT_SINK" ]]; then
        print_status ok "Sink por defecto: $LINUX_DEFAULT_SINK"
    else
        print_status err "No hay sink por defecto configurado"
    fi
}

linux_check_sources() {
    echo -e "\n${BOLD}🎤 Dispositivos de entrada (Sources)...${NC}"
    print_separator
    
    if [[ "$LINUX_AUDIO_SERVER" == "alsa" ]]; then
        if command -v arecord &>/dev/null; then
            arecord -l 2>/dev/null | grep "^card" | while read -r line; do
                print_status info "ALSA: $line"
            done
        fi
        return
    fi
    
    local sources
    sources=$(pactl list short sources 2>/dev/null)
    
    if [[ -z "$sources" ]]; then
        print_status warn "No se encontraron dispositivos de entrada"
        return
    fi
    
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        
        local source_id=$(echo "$line" | awk '{print $1}')
        local source_name=$(echo "$line" | awk '{print $2}')
        local source_desc=$(pactl list sources 2>/dev/null | grep -A 20 "Source #$source_id" | grep "Description:" | sed 's/.*: //')
        local source_state=$(pactl list sources 2>/dev/null | grep -A 20 "Source #$source_id" | grep "State:" | awk '{print $2}')
        local source_mute=$(pactl list sources 2>/dev/null | grep -A 20 "Source #$source_id" | grep "Mute:" | awk '{print $2}')
        
        LINUX_SOURCES+=("$source_name")
        
        echo
        print_status info "Source #$source_id: $source_desc"
        print_status info "  └─ Nombre: $source_name"
        print_status info "  └─ Estado: $source_state"
        
        if [[ "$source_mute" == "yes" ]]; then
            print_status warn "  └─ 🔇 MUTADO"
        else
            print_status ok "  └─ 🎤 Activo"
        fi
    done <<< "$sources"
    
    LINUX_DEFAULT_SOURCE=$(pactl info 2>/dev/null | grep "Default Source:" | awk '{print $3}')
    if [[ -n "$LINUX_DEFAULT_SOURCE" ]]; then
        echo
        print_status ok "Source por defecto: $LINUX_DEFAULT_SOURCE"
    fi
}

linux_check_modules() {
    echo -e "\n${BOLD}📦 Módulos de audio cargados...${NC}"
    print_separator
    
    # Verificar módulos del kernel
    local kernel_modules=("snd_hda_intel" "snd_usb_audio" "snd_soc_core" "snd_bcm2835")
    local found_any=false
    
    for mod in "${kernel_modules[@]}"; do
        if lsmod | grep -q "^$mod"; then
            print_status ok "Módulo kernel: $mod"
            found_any=true
        fi
    done
    
    if [[ $found_any == false ]]; then
        print_status info "No se encontraron módulos de audio específicos verificados"
        print_status info "Mostrando todos los módulos snd_*:"
        lsmod | grep "^snd" | head -5 | while read -r line; do
            print_status info "  └─ $line"
        done
    fi
    
    # Verificar módulos PulseAudio/PipeWire si aplica
    if [[ "$LINUX_AUDIO_SERVER" == "pulseaudio" ]]; then
        echo
        local pa_modules=$(pactl list short modules 2>/dev/null | wc -l)
        print_status info "Módulos PulseAudio cargados: $pa_modules"
    fi
}

linux_check_applications() {
    echo -e "\n${BOLD}🎵 Aplicaciones usando audio...${NC}"
    print_separator
    
    local inputs
    inputs=$(pactl list short sink-inputs 2>/dev/null)
    
    if [[ -z "$inputs" ]]; then
        print_status info "No hay aplicaciones reproduciendo audio"
        return
    fi
    
    local count=0
    while IFS= read -r line; do
        [[ -z "$line" ]] && continue
        
        local input_id=$(echo "$line" | awk '{print $1}')
        local sink_id=$(echo "$line" | awk '{print $2}')
        local app_name=$(pactl list sink-inputs 2>/dev/null | grep -A 30 "Sink Input #$input_id" | grep "application.name" | sed 's/.*= "//' | sed 's/"//')
        local media_name=$(pactl list sink-inputs 2>/dev/null | grep -A 30 "Sink Input #$input_id" | grep "media.name" | sed 's/.*= "//' | sed 's/"//')
        
        print_status ok "[$input_id] $app_name"
        [[ -n "$media_name" ]] && print_status info "     └─ Reproduciendo: $media_name"
        print_status info "     └─ Sink: $sink_id"
        ((count++))
    done <<< "$inputs"
    
    echo
    print_status info "Total: $count aplicación(es)"
}

linux_audio_test() {
    echo -e "\n${BOLD}🔔 TEST DE SONIDO${NC}"
    print_separator
    
    local test_passed=false
    local test_method=""
    
    # Método 1: speaker-test con PipeWire/PulseAudio
    if ! $test_passed && [[ "$LINUX_AUDIO_SERVER" != "alsa" ]]; then
        echo -e "  ${BLUE}▶ Método 1: speaker-test (sine wave)${NC}"
        if command -v speaker-test &>/dev/null; then
            # Silenciar salida para no molestar, pero verificar que no hay error
            if timeout 3 speaker-test -t sine -f 440 -c 2 -l 1 &>/dev/null; then
                print_status ok "speaker-test ejecutado sin errores"
                test_passed=true
                test_method="speaker-test"
            else
                print_status warn "speaker-test reportó errores"
            fi
        else
            print_status warn "speaker-test no disponible"
        fi
    fi
    
    # Método 2: paplay con archivo generado
    if ! $test_passed && [[ "$LINUX_AUDIO_SERVER" != "alsa" ]] && command -v paplay &>/dev/null; then
        echo -e "  ${BLUE}▶ Método 2: paplay con tono generado${NC}"
        
        # Generar archivo WAV con tono
        local tmp_file="/tmp/audio_test_$$.wav"
        if command -v sox &>/dev/null; then
            sox -n -r 44100 -c 1 "$tmp_file" synth 1 sine 440 2>/dev/null
            if [[ -f "$tmp_file" ]]; then
                if timeout 3 paplay "$tmp_file" &>/dev/null; then
                    print_status ok "paplay reprodujo el tono sin errores"
                    test_passed=true
                    test_method="paplay"
                else
                    print_status warn "paplay reportó errores"
                fi
                rm -f "$tmp_file"
            fi
        else
            print_status warn "sox no disponible para generar tono"
        fi
    fi
    
    # Método 3: aplay con ALSA
    if ! $test_passed && command -v aplay &>/dev/null; then
        echo -e "  ${BLUE}▶ Método 3: aplay (ALSA directo)${NC}"
        
        local tmp_file="/tmp/audio_test_$$.wav"
        # Generar WAV mínimo con header válido
        if command -v sox &>/dev/null; then
            sox -n -r 8000 -c 1 "$tmp_file" synth 1 sine 440 2>/dev/null
        else
            # Generar WAV crudo mínimo (silencio con header)
            printf '\x52\x49\x46\x46\x24\x00\x00\x00\x57\x41\x56\x45\x66\x6d\x74\x20\x10\x00\x00\x00\x01\x00\x01\x00\x40\x1f\x00\x00\x40\x1f\x00\x00\x02\x00\x08\x00\x64\x61\x74\x61\x00\x00\x00\x00' > "$tmp_file"
        fi
        
        if [[ -f "$tmp_file" ]]; then
            # Determinar dispositivo ALSA
            local alsa_dev="default"
            if [[ -n "$LINUX_DEFAULT_SINK" ]] && [[ "$LINUX_AUDIO_SERVER" == "pulse" ]]; then
                alsa_dev="pulse"
            fi
            
            if timeout 3 aplay -D "$alsa_dev" "$tmp_file" &>/dev/null; then
                print_status ok "aplay reprodujo sin errores"
                test_passed=true
                test_method="aplay"
            else
                print_status warn "aplay reportó errores"
            fi
            rm -f "$tmp_file"
        fi
    fi
    
    # Método 4: Parec test con cmd
    if ! $test_passed && command -v pactl &>/dev/null && [[ -n "$LINUX_DEFAULT_SINK" ]]; then
        echo -e "  ${BLUE}▶ Método 4: pactl play-sample${NC}"
        
        # Crear sample
        if command -v sox &>/dev/null; then
            local tmp_file="/tmp/audio_sample_$$.wav"
            sox -n -r 44100 -c 1 "$tmp_file" synth 1 sine 440 2>/dev/null
            if pactl upload-sample "$tmp_file" "test_tone" 2>/dev/null; then
                if timeout 3 pactl play-sample "test_tone" 2>/dev/null; then
                    print_status ok "pactl play-sample ejecutado sin errores"
                    test_passed=true
                    test_method="pactl"
                fi
                pactl remove-sample "test_tone" 2>/dev/null
            fi
            rm -f "$tmp_file"
        fi
    fi
    
    echo
    if $test_passed; then
        print_status ok "TEST SUPERADO (método: $test_method)"
        print_status info "Si no escuchaste nada, verifica volumen y conexiones físicas"
    else
        print_status err "TEST FALLIDO - No se pudo reproducir audio"
        NEEDS_REPAIR=true
    fi
}

linux_audio_repair() {
    echo -e "\n${BOLD}🔧 REPARACIÓN DE AUDIO${NC}"
    print_separator
    
    REPAIR_AVAILABLE=true
    local repairs_done=0
    
    # --- Reparación 1: Desmutear ---
    echo -e "\n  ${CYAN}▸ Desmutear dispositivos${NC}"
    if [[ -n "$LINUX_DEFAULT_SINK" ]]; then
        pactl set-sink-mute "$LINUX_DEFAULT_SINK" 0 2>/dev/null && {
            print_status ok "Sink desmuteado"
            ((repairs_done++))
        }
    fi
    if [[ -n "$LINUX_DEFAULT_SOURCE" ]]; then
        pactl set-source-mute "$LINUX_DEFAULT_SOURCE" 0 2>/dev/null && {
            print_status ok "Source desmuteado"
            ((repairs_done++))
        }
    fi
    # Desmutear todos
    pactl list short sinks | awk '{print $2}' | while read sink; do
        pactl set-sink-mute "$sink" 0 2>/dev/null
    done
    pactl list short sources | awk '{print $2}' | while read src; do
        pactl set-source-mute "$src" 0 2>/dev/null
    done
    
    # --- Reparación 2: Establecer volumen adecuado ---
    echo -e "\n  ${CYAN}▸ Ajustar volumen al 75%${NC}"
    if [[ -n "$LINUX_DEFAULT_SINK" ]]; then
        pactl set-sink-volume "$LINUX_DEFAULT_SINK" 75% 2>/dev/null && {
            print_status ok "Volumen de sink ajustado a 75%"
            ((repairs_done++))
        }
    fi
    
    # --- Reparación 3: Establecer sink por defecto ---
    echo -e "\n  ${CYAN}▸ Configurar sink por defecto${NC}"
    if [[ ${#LINUX_SINKS[@]} -gt 0 && (-z "$LINUX_DEFAULT_SINK" || "$NEEDS_REPAIR" == true) ]]; then
        local new_default="${LINUX_SINKS[0]}"
        # Preferir sinks que no sean de monitor
        for sink in "${LINUX_SINKS[@]}"; do
            if [[ ! "$sink" =~ .*monitor.* ]]; then
                new_default="$sink"
                break
            fi
        done
        
        if pactl set-default-sink "$new_default" 2>/dev/null; then
            print_status ok "Nuevo sink por defecto: $new_default"
            LINUX_DEFAULT_SINK="$new_default"
            ((repairs_done++))
        fi
    fi
    
    # --- Reparación 4: Reiniciar servidor de audio ---
    echo -e "\n  ${CYAN}▸ Reiniciar servidor de audio${NC}"
    
    case "$LINUX_AUDIO_SERVER" in
        pipewire)
            if ask_yes_no "¿Reiniciar PipeWire?" "n"; then
                systemctl --user restart pipewire.service 2>/dev/null
                systemctl --user restart pipewire-pulse.service 2>/dev/null
                systemctl --user restart wireplumber.service 2>/dev/null
                sleep 2
                if pgrep -x pipewire &>/dev/null; then
                    print_status ok "PipeWire reiniciado correctamente"
                    ((repairs_done++))
                else
                    print_status err "PipeWire no se pudo reiniciar"
                fi
            else
                print_status info "Omitido por usuario"
            fi
            ;;
        pulseaudio)
            if ask_yes_no "¿Reiniciar PulseAudio?" "n"; then
                pulseaudio -k 2>/dev/null
                sleep 1
                pulseaudio --start 2>/dev/null
                sleep 2
                if pgrep -x pulseaudio &>/dev/null; then
                    print_status ok "PulseAudio reiniciado correctamente"
                    ((repairs_done++))
                else
                    print_status err "PulseAudio no se pudo reiniciar"
                fi
            else
                print_status info "Omitido por usuario"
            fi
            ;;
        alsa)
            print_status info "ALSA no requiere servicio, verificando módulos..."
            if ask_yes_no "¿Recargar módulos ALSA?" "n"; then
                sudo modprobe -r snd_hda_intel 2>/dev/null
                sleep 1
                sudo modprobe snd_hda_intel 2>/dev/null
                print_status ok "Módulos ALSA recargados"
                ((repairs_done++))
            fi
            ;;
    esac
    
    # --- Reparación 5: Mover aplicaciones al sink correcto ---
    echo -e "\n  ${CYAN}▸ Mover aplicaciones al sink actual${NC}"
    if [[ -n "$LINUX_DEFAULT_SINK" ]]; then
        local moved=0
        pactl list short sink-inputs | awk '{print $1}' | while read input; do
            if pactl move-sink-input "$input" "$LINUX_DEFAULT_SINK" 2>/dev/null; then
                ((moved++)) || true
            fi
        done
        if [[ $moved -gt 0 ]]; then
            print_status ok "$moved aplicación(es) movida(s)"
            ((repairs_done++))
        else
            print_status info "No hay aplicaciones para mover"
        fi
    fi
    
    # --- Reparación 6: Verificar/crear configuración ---
    echo -e "\n  ${CYAN}▸ Verificar configuración${NC}"
    local config_dir="$HOME/.config/pulse"
    if [[ "$LINUX_AUDIO_SERVER" == "pulseaudio" ]]; then
        mkdir -p "$config_dir" 2>/dev/null
        if [[ ! -f "$config_dir/default.pa" ]]; then
            print_status info "Creando configuración por defecto..."
            cp /etc/pulse/default.pa "$config_dir/" 2>/dev/null && {
                print_status ok "Configuración copiada"
                ((repairs_done++))
            }
        fi
    fi
    
    echo
    print_separator
