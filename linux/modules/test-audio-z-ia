mac_detect_hardware() {
    echo -e "\n${BOLD}🖥️  Detectando hardware de audio...${NC}"
    print_separator
    
    local audio_devices
    audio_devices=$(system_profiler SPAudioDataType 2>/dev/null)
    
    if [[ -z "$audio_devices" ]]; then
        print_status err "No se pudo obtener información de audio"
        return
    fi
    
    # Extraer dispositivos de salida
    echo -e "  ${CYAN}▸ Dispositivos de salida:${NC}"
    local in_output=false
    while IFS= read -r line; do
        if [[ "$line" =~ "Output Devices:" ]]; then
            in_output=true
            continue
        elif [[ "$line" =~ "Input Devices:" ]]; then
            in_output=false
            break
        fi
        
        if $in_output; then
            if [[ "$line" =~ "_name:" ]]; then
                local name=$(echo "$line" | sed 's/.*_name: //')
                print_status ok "$name"
            elif [[ "$line" =~ "connected:" ]]; then
                local connected=$(echo "$line" | sed 's/.*connected: //')
                if [[ "$connected" == "false" || "$connected" == "no" ]]; then
                    print_status warn "  └─ Desconectado"
                fi
            fi
        fi
    done <<< "$audio_devices"
    
    # Extraer dispositivos de entrada
    echo -e "\n  ${CYAN}▸ Dispositivos de entrada:${NC}"
    local in_input=false
    while IFS= read -r line; do
        if [[ "$line" =~ "Input Devices:" ]]; then
            in_input=true
            continue
        fi
        
        if $in_input; then
            if [[ "$line" =~ "_name:" ]]; then
                local name=$(echo "$line" | sed 's/.*_name: //')
                print_status ok "$name"
            elif [[ "$line" =~ "connected:" ]]; then
                local connected=$(echo "$line" | sed 's/.*connected: //')
                if [[ "$connected" == "false" || "$connected" == "no" ]]; then
                    print_status warn "  └─ Desconectado"
                fi
            fi
        fi
    done <<< "$audio_devices"
}

mac_check_coreaudio() {
    echo -e "\n${BOLD}📡 Verificando CoreAudio...${NC}"
    print_separator
    
    # Verificar que CoreAudio esté corriendo
    if pgrep -x "coreaudiod" &>/dev/null; then
        print_status ok "CoreAudio daemon ejecutándose (PID: $(pgrep -x coreaudiod))"
    else
        print_status err "CoreAudio daemon NO está ejecutándose"
        NEEDS_REPAIR=true
    fi
    
    # Verificar permisos del daemon
    local ca_path="/System/Library/Frameworks/CoreAudio.framework/Versions/A/CoreAudio"
    if [[ -f "$ca_path" ]]; then
        print_status ok "Framework CoreAudio presente"
    fi
    
    # Verificar plugins de audio
    local plugin_dir="/Library/Audio/Plug-Ins/HAL"
    if [[ -d "$plugin_dir" ]]; then
        local plugin_count=$(ls -1 "$plugin_dir" 2>/dev/null | wc -l)
        print_status ok "Plugins HAL instalados: $plugin_count"
        ls -1 "$plugin_dir" 2>/dev/null | head -5 | while read -r plugin; do
            print_status info "  └─ $plugin"
        done
    fi
}

mac_check_volume() {
    echo -e "\n${BOLD}🔊 Verificando volumen y mute...${NC}"
    print_separator
    
    # Obtener volumen de salida
    local output_volume=$(osascript -e 'output volume of (get volume settings)' 2>/dev/null)
    local output_muted=$(osascript -e 'output muted of (get volume settings)' 2>/dev/null)
    local input_volume=$(osascript -e 'input volume of (get volume settings)' 2>/dev/null)
    local input_muted=$(osascript -e 'input muted of (get volume settings)' 2>/dev/null)
    
    if [[ -n "$output_volume" ]]; then
        print_status info "Volumen de salida: $output_volume%"
        if [[ "$output_volume" -eq 0 ]]; then
            print_status warn "Volumen de salida al mínimo"
        elif [[ "$output_volume" -lt 25 ]]; then
            print_status warn "Volumen de salida muy bajo"
        else
            print_status ok "Volumen de salida adecuado"
        fi
    fi
    
    if [[ "$output_muted" == "true" ]]; then
        print_status err "Salida de audio SILENCIADA"
        NEEDS_REPAIR=true
    else
        print_status ok "Salida de audio no silenciada"
    fi
    
    echo
    if [[ -n "$input_volume" ]]; then
        print_status info "Volumen de entrada: $input_volume%"
    fi
    
    if [[ "$input_muted" == "true" ]]; then
        print_status warn "Entrada de audio silenciada"
    else
        print_status ok "Entrada de audio activa"
    fi
    
    # Dispositivo de salida actual
    local current_device=$(osascript -e 'get name of current output device' 2>/dev/null)
    if [[ -n "$current_device" ]]; then
        echo
        print_status ok "Dispositivo de salida actual: $current_device"
    fi
}

mac_check_audio_apps() {
    echo -e "\n${BOLD}🎵 Aplicaciones usando audio...${NC}"
    print_separator
    
    # Listar apps con conexiones de audio
    local audio_apps=$(lsof 2>/dev/null | grep -i "coreaudio\|audio" | awk '{print $1}' | sort -u)
    
    if [[ -z "$audio_apps" ]]; then
        print_status info "No hay aplicaciones detectadas usando audio"
        return
    fi
    
    echo "$audio_apps" | while read -r app; do
        print_status ok "$app"
    done
}

mac_audio_test() {
    echo -e "\n${BOLD}🔔 TEST DE SONIDO${NC}"
    print_separator
    
    local test_passed=false
    
    # Método 1: afplay con sonido del sistema
    echo -e "  ${BLUE}▶ Método 1: Sonido del sistema${NC}"
    local system_sounds=(
        "/System/Library/Sounds/Glass.aiff"
        "/System/Library/Sounds/Ping.aiff"
        "/System/Library/Sounds/Pop.aiff"
        "/System/Library/Sounds/Purr.aiff"
        "/System/Library/Sounds/Tink.aiff"
        "/System/Library/Sounds/Funk.aiff"
        "/System/Library/Sounds/Blow.aiff"
        "/System/Library/Sounds/Bottle.aiff"
        "/System/Library/Sounds/Hero.aiff"
        "/System/Library/Sounds/Morse.aiff"
        "/System/Library/Sounds/Submarine.aiff"
        "/System/Library/Sounds/Sosumi.aiff"
    )
    
    for sound in "${system_sounds[@]}"; do
        if [[ -f "$sound" ]]; then
            if timeout 3 afplay "$sound" 2>/dev/null; then
                print_status ok "Reproducido: $(basename "$sound")"
                test_passed=true
                break
            else
                print_status warn "Error al reproducir: $(basename "$sound")"
            fi
        fi
    done
    
    # Método 2: say (text-to-speech)
    if ! $test_passed; then
        echo -e "  ${BLUE}▶ Método 2: Text-to-Speech${NC}"
        if timeout 3 say "Test" 2>/dev/null; then
            print_status ok "Say ejecutado sin errores"
            test_passed=true
        else
            print_status warn "Say reportó errores"
        fi
    fi
    
    # Método 3: Generar tono con sox
    if ! $test_passed && command -v sox &>/dev/null; then
        echo -e "  ${BLUE}▶ Método 3: Tono generado con sox${NC}"
        local tmp_file="/tmp/mac_audio_test_$$.aiff"
        if sox -n -r 44100 -c 1 "$tmp_file" synth 1 sine 440 2>/dev/null; then
            if timeout 3 afplay "$tmp_file" 2>/dev/null; then
                print_status ok "Tono generado reproducido"
                test_passed=true
            fi
            rm -f "$tmp_file"
        fi
    fi
    
    echo
    if $test_passed; then
        print_status ok "TEST SUPERADO"
        print_status info "Si no escuchaste nada, verifica volumen y conexiones"
    else
        print_status err "TEST FALLIDO"
        NEEDS_REPAIR=true
    fi
}

mac_audio_repair() {
    echo -e "\n${BOLD}🔧 REPARACIÓN DE AUDIO${NC}"
    print_separator
    
    REPAIR_AVAILABLE=true
    local repairs_done=0
    
    # --- Reparación 1: Desmutear ---
    echo -e "\n  ${CYAN}▸ Desmutear audio${NC}"
    if osascript -e 'set volume output muted false' 2>/dev/null; then
        print_status ok "Salida desmuteada"
        ((repairs_done++))
    fi
    if osascript -e 'set volume input muted false' 2>/dev/null; then
        print_status ok "Entrada desmuteada"
        ((repairs_done++))
    fi
    
    # --- Reparación 2: Ajustar volumen ---
    echo -e "\n  ${CYAN}▸ Ajustar volumen al 75%${NC}"
    if osascript -e "set volume output volume 75" 2>/dev/null; then
        print_status ok "Volumen ajustado a 75%"
        ((repairs_done++))
    fi
    
    # --- Reparación 3: Reiniciar CoreAudio ---
    echo -e "\n  ${CYAN}▸ Reiniciar CoreAudio${NC}"
    if ask_yes_no "¿Reiniciar CoreAudio? (requiere sudo)" "n"; then
        echo -e "  ${YELLOW}Se solicitará contraseña de administrador...${NC}"
        if sudo killall coreaudiod 2>/dev/null; then
            sleep 3
            if pgrep -x coreaudiod &>/dev/null; then
                print_status ok "CoreAudio reiniciado correctamente"
                ((repairs_done++))
            else
                print_status warn "CoreAudio no se reinició automáticamente"
                print_status info "Intentando inicio manual..."
                sudo coreaudiod &
                sleep 2
                if pgrep -x coreaudiod &>/dev/null; then
                    print_status ok "CoreAudio iniciado manualmente"
                    ((repairs_done++))
                else
                    print_status err "No se pudo iniciar CoreAudio"
                fi
            fi
        else
            print_status err "No se pudo detener CoreAudio"
        fi
    else
        print_status info "Omitido por usuario"
    fi
    
    # --- Reparación 4: Reset de configuración de audio ---
    echo -e "\n  ${CYAN}▸ Limpiar caché de audio${NC}"
    if ask_yes_no "¿Limpiar preferencias de audio?" "n"; then
        local pref_files=(
            "$HOME/Library/Preferences/com.apple.audio.AudioMIDISetup.plist"
            "$HOME/Library/Preferences/com.apple.soundpref.plist"
            "$HOME/Library/ByHost/com.apple.audio.DeviceSettings.*"
        )
        
        for pref in "${pref_files[@]}"; do
            if ls $pref &>/dev/null; then
                rm -f $pref 2>/dev/null
                print_status ok "Eliminado: $pref"
                ((repairs_done++))
            fi
        done
    else
        print_status info "Omitido por usuario"
    fi
    
    echo
    print_separator
    if [[ $repairs_done -gt 0 ]]; then
        print_status ok "Reparaciones realizadas: $repairs_done"
    else
        print_status info "No se realizaron reparaciones"
    fi
    print_separator
}

