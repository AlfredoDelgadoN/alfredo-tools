# Función auxiliar para ejecutar PowerShell
win_ps() {
    powershell.exe -NoProfile -NonInteractive -Command "$1" 2>/dev/null | tr -d '\r'
}

win_ps_admin() {
    powershell.exe -NoProfile -NonInteractive -Command "Start-Process powershell -Verb RunAs -ArgumentList '-NoProfile -NonInteractive -Command \"$1\"' -Wait" 2>/dev/null | tr -d '\r'
}

windows_detect_devices() {
    echo -e "\n${BOLD}🖥️  Detectando dispositivos de audio...${NC}"
    print_separator
    
    # Obtener dispositivos de reproducción
    echo -e "  ${CYAN}▸ Dispositivos de reproducción:${NC}"
    local playback_devices
    playback_devices=$(win_ps '
        Get-AudioDevice -List | Where-Object { $_.Type -eq "Playback" } | ForEach-Object {
            "$($_.Name)|$($_.ID)|$($_.Default)"
        }
    ')
    
    if [[ -n "$playback_devices" ]]; then
        while IFS='|' read -r name id is_default; do
            [[ -z "$name" ]] && continue
            if [[ "$is_default" == "True" ]]; then
                print_status ok "$name [POR DEFECTO]"
            else
                print_status info "$name"
            fi
        done <<< "$playback_devices"
    else
        # Método alternativo con Get-PnpDevice
        local pnp_devices
        pnp_devices=$(win_ps '
            Get-PnpDevice -Class "MEDIA" -Status OK | Where-Object { 
                $_.FriendlyName -match "audio|sound|speaker|headphone" 
            } | Select-Object -ExpandProperty FriendlyName
        ')
        
        if [[ -n "$pnp_devices" ]]; then
            echo "$pnp_devices" | while read -r device; do
                [[ -n "$device" ]] && print_status ok "$device"
            done
        else
            print_status warn "No se pudieron enumerar dispositivos de reproducción"
        fi
    fi
    
    # Obtener dispositivos de grabación
    echo -e "\n  ${CYAN}▸ Dispositivos de grabación:${NC}"
    local recording_devices
    recording_devices=$(win_ps '
        Get-AudioDevice -List | Where-Object { $_.Type -eq "Recording" } | ForEach-Object {
            "$($_.Name)|$($_.ID)|$($_.Default)"
        }
    ')
    
    if [[ -n "$recording_devices" ]]; then
        while IFS='|' read -r name id is_default; do
            [[ -z "$name" ]] && continue
            if [[ "$is_default" == "True" ]]; then
                print_status ok "$name [POR DEFECTO]"
            else
                print_status info "$name"
            fi
        done <<< "$recording_devices"
    else
        print_status warn "No se pudieron enumerar dispositivos de grabación"
    fi
}

windows_check_services() {
    echo -e "\n${BOLD}📡 Verificando servicios de audio...${NC}"
    print_separator
    
    local services=("Audiosrv" "AudioEndpointBuilder" "RpcSs" "MMCSS")
    local service_names=("Windows Audio" "Audio Endpoint Builder" "Remote Procedure Call" "Multimedia Class Scheduler")
    
    for i in "${!services[@]}"; do
        local svc="${services[$i]}"
        local svc_name="${service_names[$i]}"
        local status
        status=$(win_ps "(Get-Service -Name '$svc' -ErrorAction SilentlyContinue).Status")
        
        if [[ "$status" == "Running" ]]; then
            print_status ok "$svc_name: Ejecutándose"
        elif [[ -n "$status" ]]; then
            print_status warn "$svc_name: $status"
            NEEDS_REPAIR=true
        else
            print_status err "$svc_name: No encontrado"
            NEEDS_REPAIR=true
        fi
    done
}

windows_check_volume() {
    echo -e "\n${BOLD}🔊 Verificando volumen...${NC}"
    print_separator
    
    # Obtener volumen con AudioDevice cmdlets o método alternativo
    local volume_info
    volume_info=$(win_ps '
        $defaultDevice = Get-AudioDevice -Playback | Where-Object { $_.Default -eq $true }
        if ($defaultDevice) {
            Write-Output "Device: $($defaultDevice.Name)"
            Write-Output "Volume: $($defaultDevice.Volume)"
            Write-Output "Muted: $($defaultDevice.Muted)"
        } else {
            Write-Output "NoDefault"
        }
    ')
    
    if [[ "$volume_info" == "NoDefault" ]]; then
        print_status err "No hay dispositivo de reproducción por defecto"
        NEEDS_REPAIR=true
        return
    fi
    
    local device_name=$(echo "$volume_info" | grep "^Device:" | cut -d: -f2- | xargs)
    local volume=$(echo "$volume_info" | grep "^Volume:" | cut -d: -f2- | xargs)
    local muted=$(echo "$volume_info" | grep "^Muted:" | cut -d: -f2- | xargs)
    
    [[ -n "$device_name" ]] && print_status info "Dispositivo: $device_name"
    [[ -n "$volume" ]] && print_status info "Volumen: ${volume}%"
    
    if [[ "$muted" == "True" ]]; then
        print_status err "Audio SILENCIADO"
        NEEDS_REPAIR=true
    elif [[ -n "$muted" ]]; then
        print_status ok "Audio no silenciado"
    fi
    
    if [[ -n "$volume" ]]; then
        if [[ "$volume" -eq 0 ]]; then
            print_status warn "Volumen al mínimo"
        elif [[ "$volume" -lt 25 ]]; then
            print_status warn "Volumen muy bajo"
        fi
    fi
}

windows_check_drivers() {
    echo -e "\n${BOLD}📦 Verificando controladores de audio...${NC}"
    print_separator
    
    local drivers
    drivers=$(win_ps '
        Get-WmiObject Win32_SoundDevice | ForEach-Object {
            "$($_.Name)|$($_.Status)|$($_.StatusInfo)"
        }
    ')
    
    if [[ -z "$drivers" ]]; then
        print_status warn "No se pudieron obtener controladores"
        return
    fi
    
    while IFS='|' read -r name status status_info; do
        [[ -z "$name" ]] && continue
        print_status info "Controlador: $name"
        if [[ "$status" == "OK" ]]; then
            print_status ok "  └─ Estado: OK"
        else
            print_status warn "  └─ Estado: $status"
            NEEDS_REPAIR=true
        fi
    done <<< "$drivers"
}

windows_audio_test() {
    echo -e "\n${BOLD}🔔 TEST DE SONIDO${NC}"
    print_separator
    
    local test_passed=false
    
    # Método 1: Beep del sistema
    echo -e "  ${BLUE}▶ Método 1: Beep del sistema${NC}"
    if win_ps "[console]::Beep(440, 1000)" 2>/dev/null; then
        print_status ok "Beep ejecutado (puede no sonar si está deshabilitado)"
        # Nota: El beep de consola puede no usar el dispositivo de audio
    fi
    
    # Método 2: Reproducir sonido del sistema con PowerShell
    echo -e "  ${BLUE}▶ Método 2: Sonido del sistema via .NET${NC}"
    if win_ps '
        Add-Type -AssemblyName System.Windows.Forms
        try {
            System.Windows.Forms.SystemSounds.Beep.Play()
            Write-Output "OK"
        } catch {
            Write-Output "ERROR"
        }
    ' | grep -q "OK"; then
        print_status ok "Sonido del sistema reproducido"
        test_passed=true
    else
        print_status warn "No se pudo reproducir sonido del sistema"
    fi
    
    # Método 3: Reproducir WAV con MediaPlayer
    if ! $test_passed; then
        echo -e "  ${BLUE}▶ Método 3: Reproducir WAV con Windows Media Player${NC}"
        
        # Buscar un archivo WAV del sistema
        local wav_file
        wav_file=$(win_ps '
            $paths = @(
                "C:\Windows\Media\chimes.wav",
                "C:\Windows\Media\chord.wav",
                "C:\Windows\Media\ding.wav",
                "C:\Windows\Media\notify.wav",
                "C:\Windows\Media\Windows Notify.wav"
            )
            foreach ($p in $paths) {
                if (Test-Path $p) { Write-Output $p; break }
            }
        ')
        
        if [[ -n "$wav_file" ]]; then
            if win_ps "
                Add-Type -AssemblyName presentationCore
                \$player = New-Object System.Media.SoundPlayer('$wav_file')
                \$player.PlaySync()
            " 2>/dev/null; then
                print_status ok "WAV reproducido: $wav_file"
                test_passed=true
            else
                print_status warn "Error al reproducir WAV"
            fi
        else
            print_status warn "No se encontraron archivos WAV del sistema"
        fi
    fi
    
    # Método 4: Usar SAPI para TTS
    if ! $test_passed; then
        echo -e "  ${BLUE}▶ Método 4: Text-to-Speech${NC}"
        if win_ps '
            Add-Type -AssemblyName System.Speech
            \$synth = New-Object System.Speech.Synthesis.SpeechSynthesizer
            try {
                \$synth.Speak("Test")
                Write-Output "OK"
            } catch {
                Write-Output "ERROR"
            }
        ' | grep -q "OK"; then
            print_status ok "TTS ejecutado sin errores"
            test_passed=true
        else
            print_status warn "TTS reportó errores"
        fi
    fi
    
    echo
    if $test_passed; then
        print_status ok "TEST SUPERADO"
        print_status info "Si no escuchaste nada, verifica volumen y conexiones"
    else
        print_status err "TEST FALLIDO"
        NEEDS_REPAIR=true
    fi
}

windows_audio_repair() {
    echo -e "\n${BOLD}🔧 REPARACIÓN DE AUDIO${NC}"
    print_separator
    
    REPAIR_AVAILABLE=true
    local repairs_done=0
    
    # --- Reparación 1: Desmutear ---
    echo -e "\n  ${CYAN}▸ Desmutear audio${NC}"
    if win_ps '
        $device = Get-AudioDevice -Playback | Where-Object { $_.Default -eq $true }
        if ($device -and $device.Muted) {
            Set-AudioDevice -ID $device.ID -Mute $false
            Write-Output "OK"
        } elseif ($device) {
            Write-Output "ALREADY_UNMUTED"
        } else {
            Write-Output "NO_DEVICE"
        }
    ' | grep -q "OK"; then
        print_status ok "Audio desmuteado"
        ((repairs_done++))
    else
        print_status info "No se pudo desmutear o ya estaba desmuteado"
    fi
    
    # --- Reparación 2: Ajustar volumen ---
    echo -e "\n  ${CYAN}▸ Ajustar volumen al 75%${NC}"
    if win_ps '
        $device = Get-AudioDevice -Playback | Where-Object { $_.Default -eq $true }
        if ($device) {
            Set-AudioDevice -ID $device.ID -Volume 75
            Write-Output "OK"
        }
    ' | grep -q "OK"; then
        print_status ok "Volumen ajustado a 75%"
        ((repairs_done++))
    fi
    
    # --- Reparación 3: Reiniciar servicios ---
    echo -e "\n  ${CYAN}▸ Reiniciar servicios de audio${NC}"
    if ask_yes_no "¿Reiniciar servicios de audio? (requiere administrador)" "n"; then
        echo -e "  ${YELLOW}Se solicitarán privilegios de administrador...${NC}"
        
        # Crear script de reparación
        win_ps_admin '
            Restart-Service Audiosrv -Force -ErrorAction SilentlyContinue
            Restart-Service AudioEndpointBuilder -Force -ErrorAction SilentlyContinue
            Start-Service Audiosrv -ErrorAction SilentlyContinue
            Start-Service AudioEndpointBuilder -ErrorAction SilentlyContinue
        '
        
        sleep 2
        if win_ps "(Get-Service Audiosrv).Status" | grep -q "Running"; then
            print_status ok "Servicios de audio reiniciados"
            ((repairs_done++))
        else
            print_status err "No se pudieron reiniciar los servicios"
        fi
    else
        print_status info "Omitido por usuario"
    fi
    
    # --- Reparación 4: Reinstalar controladores ---
    echo -e "\n  ${CYAN}▸ Reinstalar controladores de audio${NC}"
    if ask_yes_no "¿Reinstalar controladores? (requiere administrador)" "n"; then
        echo -e "  ${YELLOW}Esto reinstalará los controladores de audio...${NC}"
        
        win_ps_admin '
            # Obtener dispositivos de audio con problemas
            $devices = Get-PnpDevice -Class "MEDIA" | Where-Object { $_.Status -ne "OK" }
            foreach ($dev in $devices) {
                pnputil /remove-device "$($dev.InstanceId)"
            }
            # Rescanear hardware
            pnputil /scan-devices
        '
        
        sleep 3
        print_status ok "Rescan de hardware completado"
        ((repairs_done++))
    else
        print_status info "Omitido por usuario"
    fi
    
    # --- Reparación 5: Ejecutar solucionador de problemas ---
    echo -e "\n  ${CYAN}▸ Solucionador de problemas de Windows${NC}"
    if ask_yes_no "¿Ejecutar solucionador de problemas de audio?" "n"; then
        print_status info "Iniciando solucionador..."
        win_ps_admin '
            # Intentar ejecutar el solucionador de problemas de audio
            $tspath = "C:\Windows\System32\msdt.exe"
            if (Test-Path $tspath) {
                Start-Process $tspath -ArgumentList "-id PlayingAudio -diag" -Wait
            }
        '
        print_status ok "Solucionador ejecutado"
        ((repairs_done++))
    else
        print_status info "Omitido por usuario"
    fi
    
    echo
    print_separator
    if [[ $repairs_done -gt 0 ]]; then
        print_status ok "Reparaciones realizadas: $repairs_done"
    else
        print_status info "No se realizaron reparaciones"
    fi
    print_separator
}

windows_audio_menu() {
    while true; do
        echo -e "\n${BOLD}${MAGENTA}═══════════════════════════════════════${NC}"
        echo -e "${BOLD}     🔊 DIAGNÓSTICO DE AUDIO - WINDOWS${NC}"
        echo -e "${BOLD}${MAGENTA}═══════════════════════════════════════${NC}"
        echo -e "  ${GREEN}1${NC} │ 📋 Diagnóstico completo"
        echo -e "  ${GREEN}2${NC} │ 🔔 Test de sonido"
        echo -e "  ${GREEN}3${NC} │ 🔧 Reparación"
        echo -e "  ${GREEN}4${NC} │ 🚀 Diagnóstico + Test + Reparación automática"
        echo -e "  ${YELLOW}0${NC} │ ↩️  Volver"
        echo -e "${BOLD}${MAGENTA}═══════════════════════════════════════${NC}"
        echo -en "  ${CYAN}Selecciona una opción: ${NC}"
        
        read -r option
        
        case "$option" in
            1)
                AUDIO_ERRORS=0; AUDIO_WARNINGS=0; AUDIO_OK=0; NEEDS_REPAIR=false
                windows_detect_devices
                windows_check_services
                windows_check_volume
                windows_check_drivers
                show_summary
                ;;
            2)
                windows_check_volume
                windows_audio_test
                ;;
            3)
                windows_audio_repair
                ;;
            4)
                AUDIO_ERRORS=0; AUDIO_WARNINGS=0; AUDIO_OK=0; NEEDS_REPAIR=false
                windows_detect_devices
                windows_check_services
                windows_check_volume
                windows_check_drivers
                windows_audio_test
                if [[ $NEEDS_REPAIR == true ]]; then
                    echo
                    if ask_yes_no "¿Deseas intentar reparar automáticamente?" "y"; then
                        windows_audio_repair
                    fi
                fi
                show_summary
                ;;
            0)
                return 0
                ;;
            *)
                echo -e "  ${RED}Opción no válida${NC}"
                ;;
        esac
    done
}

# ============================================
#          MENÚ PRINCIPAL
# ============================================

detect_os() {
    case "$OSTYPE" in
        linux-gnu*)   echo "linux" ;;
        darwin*)      echo "mac" ;;
        msys*|cygwin*|win32) echo "windows" ;;
        *)            echo "unknown" ;;
    esac
}

main() {
    local os=$(detect_os)
    
    title "🔊 DIAGNÓSTICO DE AUDIO MULTIPLATAFORMA"
    echo -e "  ${BLUE}Sistema detectado: ${BOLD}$(uname -s)${NC}"
    echo -e "  ${BLUE}Plataforma: ${BOLD}$os${NC}"
    separator
    
    case "$os" in
        linux)
            if ! command -v pactl &>/dev/null && ! command -v aplay &>/dev/null; then
                echo -e "  ${RED}❌ No se encontraron herramientas de audio (pactl/aplay)${NC}"
                echo -e "  ${YELLOW}Instala: pulseaudio-utils o pipewire-pulse${NC}"
                exit 1
            fi
            linux_audio_menu
            ;;
        mac)
            if ! command -v osascript &>/dev/null; then
                echo -e "  ${RED}❌ osascript no disponible${NC}"
                exit 1
            fi
            mac_audio_menu
            ;;
        windows)
            if ! command -v powershell.exe &>/dev/null; then
                echo -e "  ${RED}❌ PowerShell no disponible${NC}"
                exit 1
            fi
            # Verificar módulo AudioDevice
            if ! win_ps "Get-Command Get-AudioDevice -ErrorAction SilentlyContinue" &>/dev/null; then
                echo -e "  ${YELLOW}⚠️  Módulo AudioDevice no instalado${NC}"
                echo -e "  ${YELLOW}Instala con: Install-Module AudioDevice -Scope CurrentUser${NC}"
                echo -e "  ${YELLOW}Continuando con métodos alternativos...${NC}"
                echo
            fi
            windows_audio_menu
            ;;
        *)
            echo -e "  ${RED}❌ Sistema operativo no soportado: $OSTYPE${NC}"
            exit 1
            ;;
    esac
    
    ok "Módulo de audio finalizado"
}

# Ejecutar si se llama directamente
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main
fi
