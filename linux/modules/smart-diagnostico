#!/bin/bash

BASE="${ALFREDO_BASE:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
source "$BASE/lib/ui"

title "💿 Diagnóstico SMART de Discos"

# ============================================================
# FUNCIONES DE DIAGNÓSTICO
# ============================================================

# Verificar si smartctl está instalado
if ! command -v smartctl &>/dev/null; then
    error "smartctl no está instalado"
    echo "  Instala con: sudo apt install smartmontools -y"
    exit 1
fi

# Función para analizar NVMe
analyze_nvme() {
    local DEVICE="$1"
    local SMART_INFO=$(sudo smartctl -A "$DEVICE" 2>/dev/null)
    
    echo -e "${BOLD}${CYAN}📀 Disco: $(basename $DEVICE) (NVMe)${RESET}"
    separator
    
    # Información básica
    echo -e "${BLUE}📋 Información del disco:${RESET}"
    sudo smartctl -i "$DEVICE" 2>/dev/null | grep -E "Model Number:|Serial Number:|Firmware Version:|NVMe Version:|Total NVM Capacity:" | sed 's/^/  /'
    echo
    
    # Salud
    echo -e "${BLUE}🏥 Salud SMART:${RESET}"
    HEALTH=$(sudo smartctl -H "$DEVICE" 2>/dev/null | grep "SMART overall-health" | cut -d: -f2 | xargs)
    if echo "$HEALTH" | grep -qi "PASSED"; then
        echo -e "  ${GREEN}✅ $HEALTH${RESET}"
    else
        echo -e "  ${RED}❌ $HEALTH${RESET}"
    fi
    echo
    
    # Atributos NVMe
    echo -e "${BLUE}📊 Atributos NVMe:${RESET}"
    
    # Temperatura
    TEMP=$(echo "$SMART_INFO" | grep -E "^Temperature:" | awk '{print $2}' | sed 's/°C//')
    if [ -n "$TEMP" ] && [ "$TEMP" -gt 0 ] 2>/dev/null; then
        echo -n "  🌡️  Temperatura: ${TEMP}°C"
        [ "$TEMP" -gt 70 ] && echo -e "  ${RED}🔥 CRÍTICA!${RESET}" || \
        [ "$TEMP" -gt 60 ] && echo -e "  ${YELLOW}⚠️  Elevada${RESET}" || \
        [ "$TEMP" -gt 50 ] && echo -e "  ${YELLOW}⚠️  Alta${RESET}" || \
        echo -e "  ${GREEN}✅ Normal${RESET}"
    fi
    
    # Porcentaje usado
    PERCENT=$(echo "$SMART_INFO" | grep "Percentage Used:" | awk '{print $3}' | sed 's/%//')
    if [ -n "$PERCENT" ] && [ "$PERCENT" -gt 0 ] 2>/dev/null; then
        REMAINING=$((100 - PERCENT))
        echo -e "  📊 Vida útil estimada: ${GREEN}$REMAINING%${RESET} restante"
        [ "$PERCENT" -gt 80 ] && echo -e "     ${RED}⚠️  Desgaste alto! Considera reemplazar el disco${RESET}" || \
        [ "$PERCENT" -gt 50 ] && echo -e "     ${YELLOW}⚠️  Desgaste moderado${RESET}" || \
        echo -e "     ${GREEN}✅ Desgaste bajo${RESET}"
    fi
    
    # Horas encendido
    HOURS=$(echo "$SMART_INFO" | grep "Power On Hours:" | awk '{print $4}' | sed 's/,//g' | sed 's/\.//g' | sed 's/[^0-9]//g')
    if [ -n "$HOURS" ] && [ "$HOURS" -gt 0 ] 2>/dev/null; then
        DAYS=$((HOURS / 24))
        echo "  ⏱️  Horas encendido: $HOURS horas (~${DAYS} días)"
    fi
    
    # Datos leídos/escritos
    READ=$(echo "$SMART_INFO" | grep "Data Units Read:" | awk '{print $4}' | sed 's/,//g')
    READ_UNIT=$(echo "$SMART_INFO" | grep "Data Units Read:" | awk '{print $5}')
    WRITTEN=$(echo "$SMART_INFO" | grep "Data Units Written:" | awk '{print $4}' | sed 's/,//g')
    WRITTEN_UNIT=$(echo "$SMART_INFO" | grep "Data Units Written:" | awk '{print $5}')
    [ -n "$READ" ] && [ "$READ" -gt 0 ] 2>/dev/null && echo "  📖 Datos leídos: $READ $READ_UNIT"
    [ -n "$WRITTEN" ] && [ "$WRITTEN" -gt 0 ] 2>/dev/null && echo "  📝 Datos escritos: $WRITTEN $WRITTEN_UNIT"
    
    # Errores
    ERRORS=$(echo "$SMART_INFO" | grep "Media and Data Integrity Errors:" | awk '{print $4}' | sed 's/,//g')
    if [ -n "$ERRORS" ] && [ "$ERRORS" -ge 0 ] 2>/dev/null; then
        [ "$ERRORS" -eq 0 ] && echo -e "  ✅ Errores de integridad: 0" || echo -e "  🔴 Errores de integridad: ${RED}$ERRORS${RESET}"
    fi
    
    # Apagados inseguros
    UNSAFE=$(echo "$SMART_INFO" | grep "Unsafe Shutdowns:" | awk '{print $3}' | sed 's/,//g')
    if [ -n "$UNSAFE" ] && [ "$UNSAFE" -ge 0 ] 2>/dev/null; then
        if [ "$UNSAFE" -gt 10 ]; then
            echo -e "  🔴 Apagados inseguros: ${YELLOW}$UNSAFE${RESET} ⚠️"
        else
            echo "  ✅ Apagados inseguros: $UNSAFE"
        fi
    fi
    
    # Resumen
    echo
    echo -e "${BLUE}📋 Resumen:${RESET}"
    PROBLEMS=0
    [ -n "$TEMP" ] && [ "$TEMP" -gt 70 ] 2>/dev/null && PROBLEMS=$((PROBLEMS+1))
    [ -n "$PERCENT" ] && [ "$PERCENT" -gt 80 ] 2>/dev/null && PROBLEMS=$((PROBLEMS+1))
    [ -n "$ERRORS" ] && [ "$ERRORS" -gt 0 ] 2>/dev/null && PROBLEMS=$((PROBLEMS+1))
    
    if [ "$PROBLEMS" -eq 0 ]; then
        echo -e "  ${GREEN}✅ NVMe en excelente estado${RESET}"
    elif [ "$PROBLEMS" -lt 2 ]; then
        echo -e "  ${YELLOW}⚠️  NVMe con algunos problemas (monitorear)${RESET}"
    else
        echo -e "  ${RED}❌ NVMe con problemas críticos - ¡Reemplazar pronto!${RESET}"
    fi
    echo
}

# Función para analizar SATA SSD/HDD
analyze_sata() {
    local DEVICE="$1"
    local SMART_INFO=$(sudo smartctl -A "$DEVICE" 2>/dev/null)
    
    echo -e "${BOLD}${CYAN}📀 Disco: $(basename $DEVICE) (SATA)${RESET}"
    separator
    
    # Información básica
    echo -e "${BLUE}📋 Información del disco:${RESET}"
    sudo smartctl -i "$DEVICE" 2>/dev/null | grep -E "Model Family:|Device Model:|Serial Number:|Firmware Version:|User Capacity:|Rotation Rate:|Form Factor:|SATA Version:" | sed 's/^/  /'
    echo
    
    # Salud
    echo -e "${BLUE}🏥 Salud SMART:${RESET}"
    HEALTH=$(sudo smartctl -H "$DEVICE" 2>/dev/null | grep "SMART overall-health" | cut -d: -f2 | xargs)
    if echo "$HEALTH" | grep -qi "PASSED"; then
        echo -e "  ${GREEN}✅ $HEALTH${RESET}"
    else
        echo -e "  ${RED}❌ $HEALTH${RESET}"
    fi
    echo
    
    # Atributos SATA
    echo -e "${BLUE}📊 Atributos SMART:${RESET}"
    
    # Temperatura
    TEMP=$(echo "$SMART_INFO" | grep -E "Temperature_Celsius|Airflow_Temperature" | head -1 | awk '{print $10}')
    if [ -n "$TEMP" ]; then
        echo -n "  🌡️  Temperatura: ${TEMP}°C"
        [ "$TEMP" -gt 70 ] && echo -e "  ${RED}🔥 CRÍTICA!${RESET}" || \
        [ "$TEMP" -gt 60 ] && echo -e "  ${YELLOW}⚠️  Elevada${RESET}" || \
        [ "$TEMP" -gt 50 ] && echo -e "  ${YELLOW}⚠️  Alta${RESET}" || \
        echo -e "  ${GREEN}✅ Normal${RESET}"
    fi
    
    # Horas encendido
    POWER_ON=$(echo "$SMART_INFO" | grep -E "Power_On_Hours" | awk '{print $10}')
    if [ -n "$POWER_ON" ]; then
        DAYS=$((POWER_ON / 24))
        echo "  ⏱️  Horas encendido: $POWER_ON horas (~${DAYS} días)"
    fi
    
    # Sector reasignados
    REALLOC=$(echo "$SMART_INFO" | grep "Reallocated_Sector" | awk '{print $10}')
    if [ -n "$REALLOC" ]; then
        if [ "$REALLOC" -gt 0 ]; then
            echo -e "  🔴 Sectores reasignados: ${YELLOW}$REALLOC${RESET} ⚠️"
        else
            echo "  ✅ Sectores reasignados: 0"
        fi
    fi
    
    # Wear Leveling (SSD Samsung)
    WEAR=$(echo "$SMART_INFO" | grep "Wear_Leveling_Count" | awk '{print $10}')
    if [ -n "$WEAR" ]; then
        echo -n "  📊 Desgaste: "
        if [ "$WEAR" -gt 80 ]; then
            echo -e "${RED}${WEAR}% ⚠️${RESET}"
        elif [ "$WEAR" -gt 50 ]; then
            echo -e "${YELLOW}${WEAR}%${RESET}"
        else
            echo -e "${GREEN}${WEAR}%${RESET}"
        fi
    fi
    
    # Porcentaje usado (para SSD)
    PERCENT_USED=$(echo "$SMART_INFO" | grep -E "Percentage_Used|Percent_Lifetime" | awk '{print $10}')
    if [ -n "$PERCENT_USED" ]; then
        REMAINING=$((100 - PERCENT_USED))
        echo -e "  📊 Vida útil estimada: ${GREEN}$REMAINING%${RESET} restante"
    fi
    
    # Errores
    ERRORS=$(echo "$SMART_INFO" | grep "Uncorrectable_Error" | awk '{print $10}')
    if [ -n "$ERRORS" ]; then
        if [ "$ERRORS" -eq 0 ]; then
            echo -e "  ✅ Errores no corregibles: 0"
        else
            echo -e "  🔴 Errores no corregibles: ${RED}$ERRORS${RESET}"
        fi
    fi
    
    # Resumen
    echo
    echo -e "${BLUE}📋 Resumen:${RESET}"
    PROBLEMS=0
    [ -n "$TEMP" ] && [ "$TEMP" -gt 70 ] 2>/dev/null && PROBLEMS=$((PROBLEMS+1))
    [ -n "$REALLOC" ] && [ "$REALLOC" -gt 0 ] 2>/dev/null && PROBLEMS=$((PROBLEMS+1))
    [ -n "$WEAR" ] && [ "$WEAR" -gt 80 ] 2>/dev/null && PROBLEMS=$((PROBLEMS+1))
    
    if [ "$PROBLEMS" -eq 0 ]; then
        echo -e "  ${GREEN}✅ Disco en excelente estado${RESET}"
    elif [ "$PROBLEMS" -lt 2 ]; then
        echo -e "  ${YELLOW}⚠️  Disco con algunos problemas (monitorear)${RESET}"
    else
        echo -e "  ${RED}❌ Disco con problemas críticos - ¡Reemplazar pronto!${RESET}"
    fi
    echo
}

# ============================================================
# MENÚ PRINCIPAL
# ============================================================

echo -e "${BLUE}🔍 Detectando discos...${RESET}"
separator

# Listar discos disponibles
DISKS=()
for DISK in $(lsblk -d -o NAME,TYPE | grep disk | awk '{print $1}' | grep -v "zram\|loop"); do
    DISKS+=("$DISK")
done

if [ ${#DISKS[@]} -eq 0 ]; then
    error "No se encontraron discos"
    exit 1
fi

echo "Discos encontrados:"
for i in "${!DISKS[@]}"; do
    MODEL=$(lsblk -d -o MODEL "/dev/${DISKS[$i]}" 2>/dev/null | tail -1)
    echo "  $((i+1))) ${DISKS[$i]} ${MODEL:+, $MODEL}"
done
echo

# Preguntar qué hacer
echo -e "${BLUE}¿Qué deseas hacer?${RESET}"
echo "  1) Analizar todos los discos"
echo "  2) Seleccionar un disco específico"
echo "  3) Salir"
echo
read -p "Opción (1-3): " OPCION

case $OPCION in
    1)
        for DISK in "${DISKS[@]}"; do
            DEVICE="/dev/$DISK"
            if echo "$DISK" | grep -q "nvme"; then
                analyze_nvme "$DEVICE"
            else
                analyze_sata "$DEVICE"
            fi
        done
        ;;
    2)
        echo
        read -p "Número de disco a analizar (1-${#DISKS[@]}): " NUM
        if [ "$NUM" -ge 1 ] && [ "$NUM" -le ${#DISKS[@]} ]; then
            DISK="${DISKS[$((NUM-1))]}"
            DEVICE="/dev/$DISK"
            if echo "$DISK" | grep -q "nvme"; then
                analyze_nvme "$DEVICE"
            else
                analyze_sata "$DEVICE"
            fi
        else
            error "Opción inválida"
            exit 1
        fi
        ;;
    3)
        echo "Saliendo..."
        exit 0
        ;;
    *)
        error "Opción inválida"
        exit 1
        ;;
esac

echo
ok "Diagnóstico SMART completado"
