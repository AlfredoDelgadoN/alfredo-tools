#!/bin/bash
# lib/ui - Alfredo Tools UI Functions

# Colores
GREEN="\e[32m"
RED="\e[31m"
YELLOW="\e[33m"
BLUE="\e[34m"
CYAN="\e[36m"
BOLD="\e[1m"
RESET="\e[0m"

WIDTH=50

# Funciones UI
separator() {
    printf -- '-%.0s' $(seq 1 $WIDTH)
    echo
}

title() {
    clear 2>/dev/null || true
    printf "${BOLD}${CYAN}"
    printf '%*s\n' $WIDTH '' | tr ' ' '='
    printf "%*s\n" $(( (${#1} + WIDTH) / 2 )) "$1"
    printf '%*s\n' $WIDTH '' | tr ' ' '='
    printf "${RESET}"
}

field() {
    printf "${BLUE}%-15s${RESET}: %s\n" "$1" "$2"
}

ok() {
    echo
    echo -e "${GREEN}✔ $1${RESET}"
}

error() {
    echo
    echo -e "${RED}✖ $1${RESET}"
}

warn() {
    echo
    echo -e "${YELLOW}⚠ $1${RESET}"
}

info() {
    echo
    echo -e "${CYAN}ℹ $1${RESET}"
}

# Función para debug (opcional)
debug() {
    if [ "$DEBUG" = "true" ]; then
        echo -e "${YELLOW}[DEBUG] $1${RESET}"
    fi
}
EOF
